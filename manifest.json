{
  "manifest_version": 3,
  "name": "MindfulCloud",
  "version": "3.1",
  "description": "Minimal focus-based UI theme.",
  "permissions": ["storage"],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.pinterest.com/*"
  ],
  "action": {
    "default_icon": {
      "16": "icon/16.png",
      "32": "icon/32.png"
    },
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icon/16.png",
    "32": "icon/32.png",
    "48": "icon/48.png",
    "128": "icon/128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.pinterest.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/youtube-clean.css"],
      "matches": ["*://*.youtube.com/*"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "mindful-new-v2@yourextension.com",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  } 
}
