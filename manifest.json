{
  "manifest_version": 3,
  "name": "MindFulCloud",
  "version": "2.8",
  "description": "De-clutter your digital space across multiple platforms.",

  "permissions": ["storage"],

  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.reddit.com/*",
    "*://*.twitter.com/*",
    "*://*.x.com/*"
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": "icons/icon48.png"
  },

  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "css": ["styles/youtube-clean.css"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.reddit.com/*"],
      "js": ["content.js"],
      "css": ["styles/reddit-clean.css"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.twitter.com/*", "*://*.x.com/*"],
      "js": ["content.js"],
      "css": ["styles/twitter-clean.css"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.pinterest.com/*"],
      "js": ["content.js"],
      "css": ["styles/pinterest-clean.css"],
      "run_at": "document_start"
    }
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "mindful-new-v2@yourextension.com"
    }
  }
}
